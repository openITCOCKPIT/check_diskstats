import os
import sys
import argparse
from time import time, mktime
from datetime import datetime

try:
    from configparser import ConfigParser
except ImportError:
    from ConfigParser import ConfigParser

try:
    from pyudev import Context, Device
    HAVE_UDEV = True
except ImportError:
    HAVE_UDEV = False

def check_disk(disk_name, warning_threshold, critical_threshold):
    """
    Führt die Prüfung für eine einzelne Disk durch.
    Gibt (exit_code, human_text, perf_data) zurück.
    """
    disk = os.path.basename(disk_name)
    state_file = f"/dev/shm/diskstats.{disk}"
    
    state = ConfigParser()
    havestate = bool(state.read(state_file)) and state.has_section("state")
    exit_code = 0

    try:
        with open(f"/sys/block/{disk}/stat", "rb") as fd:
            currstate = dict(zip((
                "rd_ios", "rd_merges", "rd_sectors", "rd_ticks",
                "wr_ios", "wr_merges", "wr_sectors", "wr_ticks",
                "ios_in_prog", "tot_ticks", "rq_ticks"
            ), [int(count) for count in fd.read().split()]))
            currstate["timestamp"] = time()
    except IOError:
        return 3, f"{disk}: UNKNOWN (Read Error)", ""

    createstamp = None
    dev = None
    if HAVE_UDEV:
        try:
            ctx = Context()
            dev = Device.from_name(ctx, "block", disk)
            createstamp = int(mktime((datetime.now() - dev.time_since_initialized).timetuple()))
        except Exception:
            pass

    if havestate:
        if not state.has_section("device") or \
           (createstamp is not None and state.getint("device", "initialized", fallback=0) != createstamp):
            havestate = False
        if HAVE_UDEV and dev and "DM_UUID" in dev.keys() and \
           state.get("device", "uuid", fallback="") != dev.get("DM_UUID"):
            havestate = False

    if not havestate:
        if not state.has_section("device"): state.add_section("device")
        if createstamp is not None: state.set("device", "initialized", str(createstamp))
        if HAVE_UDEV and dev and "DM_UUID" in dev.keys(): state.set("device", "uuid", dev.get("DM_UUID"))

    def wrapdiff(curr, last):
        if last <= curr: return curr - last
        for chkbound in (64,63,32,31,16,15):
            if last > 2**chkbound: break
            return 2**chkbound - last + curr
        return curr

    human_text = ""
    perf_data = ""

    if havestate:
        bytes_per_sector = 512
        interval = float(currstate["timestamp"] - state.getfloat("state", "timestamp"))
        if interval <= 0: interval = 0.001

        rd_ios = wrapdiff(currstate["rd_ios"], state.getfloat("state", "rd_ios"))
        wr_ios = wrapdiff(currstate["wr_ios"], state.getfloat("state", "wr_ios"))
        rd_ticks = wrapdiff(currstate["rd_ticks"], state.getfloat("state", "rd_ticks"))
        wr_ticks = wrapdiff(currstate["wr_ticks"], state.getfloat("state", "wr_ticks"))
        rd_sectors = wrapdiff(currstate["rd_sectors"], state.getfloat("state", "rd_sectors"))
        wr_sectors = wrapdiff(currstate["wr_sectors"], state.getfloat("state", "wr_sectors"))
        tot_ticks = wrapdiff(currstate["tot_ticks"], state.getfloat("state", "tot_ticks"))

        rd_iops, wr_iops = rd_ios / interval, wr_ios / interval
        rd_bps = (rd_sectors / interval) * bytes_per_sector
        wr_bps = (wr_sectors / interval) * bytes_per_sector
        tot_ios = rd_ios + wr_ios
        tot_iops = tot_ios / interval
        
        rd_avg_size = (rd_sectors * bytes_per_sector / rd_ios) if rd_ios else 0
        wr_avg_size = (wr_sectors * bytes_per_sector / wr_ios) if wr_ios else 0
        
        util_percent = (tot_ticks / (interval * 1000.)) * 100.

        if util_percent > warning_threshold: exit_code = 1
        if util_percent > critical_threshold: exit_code = 2

        status_str = "OK"
        if exit_code == 1: status_str = "WARNING"
        if exit_code == 2: status_str = "CRITICAL"

        human_text = f"{disk}: {status_str} ({util_percent:.2f}%)"
        
        # Performance Data Strings (Key=Value;Warn;Crit;Min;Max)
        perf_data = (f"{disk}_util={util_percent:.2f}%;{warning_threshold};{critical_threshold};0;100 "
                     f"{disk}_rd_iops={rd_iops:.2f} {disk}_wr_iops={wr_iops:.2f} "
                     f"{disk}_rd_bps={rd_bps:.2f}B {disk}_wr_bps={wr_bps:.2f}B")
    else:
        human_text = f"{disk}: INITIALIZING"
        exit_code = 3
        if not state.has_section("state"): state.add_section("state")

    # Save State for next run
    for key, val in currstate.items():
        state.set("state", key, str(val))
    with open(state_file, "w") as f:
        state.write(f)
    
    return exit_code, human_text, perf_data

# --- Main ---

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Nagios Disk Stats Check")
    parser.add_argument("-w", "--warning", type=float, default=75, help="Warning threshold (util %)")
    parser.add_argument("-c", "--critical", type=float, default=85, help="Critical threshold (util %)")
    parser.add_argument("disk", nargs='?', help="Disk name (e.g. sda). If omitted, all disks are checked.")
    args = parser.parse_args()

    # Disk-Auswahl
    if args.disk:
        disks_to_check = [args.disk]
    else:
        # Finde alle relevanten Block-Geräte, ignoriere Partitionen, Loop-Devices und RAM-Disks
        disks_to_check = [d for d in os.listdir("/sys/block/") 
                          if not d.startswith(("loop", "ram", "zram"))]

    overall_exit_code = 0
    all_summaries = []
    all_perfdata = []

    for d in disks_to_check:
        rc, txt, perf = check_disk(d, args.warning, args.critical)
        all_summaries.append(txt)
        if perf:
            all_perfdata.append(perf)
        
        # Der höchste Status gewinnt (0 < 3 < 1 < 2 in Nagios-Priorität, 
        # hier vereinfacht über max() da 2 der höchste ist)
        if rc == 1 and overall_exit_code == 0: overall_exit_code = 1
        if rc == 2: overall_exit_code = 2
        if rc == 3 and overall_exit_code == 0: overall_exit_code = 3

    final_output = f"{', '.join(all_summaries)} | {' '.join(all_perfdata)}"
    print(final_output)
    
    sys.exit(overall_exit_code)
